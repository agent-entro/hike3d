{
  "name": "hike3d",
  "version": "0.1.0",
  "description": "3D hiking trail viewer",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=server/"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  }
}

# Copy to client/.env and adjust as needed.

# Default build hash used in development.
# Override at CI build time: VITE_BUILD_HASH=$(git rev-parse --short HEAD) npm run build
VITE_BUILD_HASH=dev

# Port the Express API server listens on. Must match PORT in the root .env.
# Used by vite.config.js to point the dev proxy at the correct server port.
SERVER_PORT=3004
